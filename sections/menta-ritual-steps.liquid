<section class="menta-ritual-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="menta-ritual-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="menta-ritual-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="menta-ritual-grid">
      {% for block in section.blocks %}
        <div class="menta-ritual-step">
          <div class="menta-ritual-step-number">0{{ forloop.index }}</div>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" class="menta-ritual-image" loading="lazy">
          {% else %}
            <div class="menta-ritual-image-placeholder"></div>
          {% endif %}
          <h3 class="menta-ritual-step-title">{{ block.settings.title }}</h3>
          <p class="menta-ritual-step-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .menta-ritual-section {
    padding: 80px 0;
    background-color: var(--color-base-background-1);
    text-align: center;
  }
  .menta-ritual-heading {
    font-family: var(--font-heading-family);
    color: var(--color-base-text);
    font-size: 3.2rem;
    margin-bottom: 15px;
    font-weight: 500;
  }
  .menta-ritual-subheading {
    font-family: var(--font-body-family);
    color: var(--color-base-text-opacity-85);
    font-size: 1.6rem;
    margin-bottom: 60px;
  }
  .menta-ritual-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  @media screen and (max-width: 768px) {
    .menta-ritual-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .menta-ritual-section {
      padding: 50px 0;
    }
  }
  .menta-ritual-step {
    position: relative;
    padding: 30px 20px;
    background-color: var(--color-base-background-2); /* İkincil krem arkaplan */
    border-radius: var(--buttons-radius);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid rgba(42,42,42,0.05);
  }
  .menta-ritual-step:hover {
    transform: translateY(-8px);
    box-shadow: 0 10px 20px rgba(42,42,42,0.05);
  }
  .menta-ritual-step-number {
    position: absolute;
    top: -25px;
    left: 20px;
    font-family: var(--font-heading-family);
    font-size: 5rem;
    color: var(--color-base-accent-2); /* Mat Gold numara */
    opacity: 0.4;
    line-height: 1;
    z-index: 0;
  }
  .menta-ritual-image {
    width: 100%;
    height: auto;
    border-radius: var(--buttons-radius);
    margin-bottom: 25px;
    position: relative;
    z-index: 1;
    mix-blend-mode: multiply; /* Transparan görsellerin krem arkaplana kusursuz oturması için */
  }
  .menta-ritual-image-placeholder {
    width: 100%;
    height: 200px;
    background-color: #EAE6DF;
    border-radius: var(--buttons-radius);
    margin-bottom: 25px;
    position: relative;
    z-index: 1;
  }
  .menta-ritual-step-title {
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    color: var(--color-base-text);
    margin-bottom: 12px;
    position: relative;
    z-index: 1;
  }
  .menta-ritual-step-text {
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    color: var(--color-base-text-opacity-85);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }
</style>

{% schema %}
{
  "name": "Menta Ritual Steps",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "6 Adımlı Komple Ayak Bakım Ritüeli"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Menta & Co. ile kendinize ayırdığınız bu lüks anın tadını çıkarın."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Ritual Step",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image/Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Adım Başlığı"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Description",
          "default": "Bu adımın detaylı açıklamasını buraya girin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Menta Ritual Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Hazırlık", "text": "Ilık suyla ayaklarınızı 5 dakika dinlendirin." } },
        { "type": "step", "settings": { "title": "Peeling", "text": "Peeling maskesini giyin ve 60 dakika bekleyin." } },
        { "type": "step", "settings": { "title": "Törpüleme", "text": "Ahşap törpü ile ölü derilerden arının." } },
        { "type": "step", "settings": { "title": "Nemlendirme", "text": "Ayak bakım kremini nazikçe masaj yaparak yedirin." } },
        { "type": "step", "settings": { "title": "Silikon Çorap", "text": "Pembe silikon çorabı giyerek nemi hapsedin." } },
        { "type": "step", "settings": { "title": "Günlük Koruma", "text": "Temiz çorabınızı giyerek güne bebeksi ayaklarla başlayın." } }
      ]
    }
  ]
}
{% endschema %}
